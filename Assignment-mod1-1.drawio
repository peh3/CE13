          <mxGeometry height="37.5" width="450" x="919.5" y="62.5" as="geometry" />
        </mxCell>
        <mxCell id="MD-2hdUek0shxu8cgxFw-135" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;p class=&quot;p1&quot; style=&quot;margin: 0px; font-style: normal; font-variant: normal; font-size-adjust: none; font-language-override: normal; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-stretch: normal; font-size: 11px; line-height: normal; font-family: Helvetica; color: rgb(27, 35, 46);&quot;&gt;Use an internet-facing Application Load&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Balancer to distribute web traffic to your&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;web servers spread across multiple&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;availability zones.&lt;/span&gt;&lt;/p&gt;" vertex="1">
